# ─────────────────────────────────────────────────────────────
#  X Automation — Environment Variable Baseline Template
#  Copy this file to .env and fill in your values.
#  NEVER commit your .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── LLM (DeepInfra) ──────────────────────────────────────────
# Your DeepInfra API token. Get one at https://deepinfra.com/
DEEPINFRA_TOKEN=your_deepinfra_token_here

# ── RAG Web Search (Serper.dev) ──────────────────────────────
# Used to fetch real-time Google search context before LLM generation.
# Get a free API key at https://serper.dev/ (2,500 free queries/month).
SERPER_API_KEY=your_serper_api_key_here

# ── Session Authentication ────────────────────────────────────
# Path to the saved Playwright browser storageState (cookies + localStorage).
# Generate this file by running: npm run auth
# SECURITY: This file contains live session tokens. Add it to .gitignore.
AUTH_SESSION_PATH=./auth/session.json

# ── Tweet Generation & Engagement ───────────────────────────────────────────
# The subject/context for the LLM to tweet about.
# Example: "AI productivity tools", "Web3 opinions", "tech industry takes"
TOPIC=AI and software engineering

# Posting mode: ORIGINAL_POST | REPLY | RETWEET
# Use 'npm run configure' to switch modes interactively.
MODE=ORIGINAL_POST

# Tone / persona for LLM-generated content.
# Options: pragmatic | tech-founder | cynical | educational | provocative
TONE_STYLE=pragmatic

# Hard character limit for generated posts (100–280).
TWEET_MAX_LENGTH=240

# Comma-separated X handles to engage with in REPLY / RETWEET modes (no @).
# Example: sama,karpathy,levelsio
TARGET_HANDLES=

# ── Safety Controls ──────────────────────────────────────────
# When HUMAN_IN_THE_LOOP=true, the script will:
#   1. Print the LLM draft to the terminal and ask for confirmation.
#   2. Pause again right before clicking the Post button.
# Set to false to run fully autonomously (use with caution).
HUMAN_IN_THE_LOOP=true

# ── Browser Configuration ────────────────────────────────────
# Set HEADLESS=false for authentic browser fingerprinting (recommended).
# Set HEADLESS=true only for CI/server environments (more detectable).
HEADLESS=false
